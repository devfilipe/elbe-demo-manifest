<?xml version="1.0" encoding="UTF-8"?>
<manifest>

        <remote name="devfilipe" fetch="git@github.com-devfilipe:devfilipe/" />

        <default remote="devfilipe" revision="main" sync-j="4" />

        <!-- Dev container (Dockerfile, entrypoint, compose) -->
        <project name="elbe-devcontainers" path="tools/elbe-devcontainers" />

        <!-- Lightweight web UI for ELBE -->
        <project name="elbe-ui" path="tools/elbe-ui" />

        <!-- Custom APT repository tooling (pool layout, SBOM-compatible) -->
        <project name="elbe-demo-apt-repository" path="tools/elbe-demo-apt-repository" />

        <!-- Custom APT repository tooling (flat layout) -->
        <project name="elbe-demo-apt-repository-flat" path="tools/elbe-demo-apt-repository-flat" />

        <!-- Sample hello application source -->
        <project name="elbe-demo-app-hello" path="sources/elbe-demo-app-hello" />

        <!-- Debian package definition for hello -->
        <project name="elbe-demo-pkg-hello" path="packages/elbe-demo-pkg-hello" />

        <!-- ELBE XML project definitions -->
        <project name="elbe-demo-projects" path="projects/elbe-demo-projects" />

</manifest>
